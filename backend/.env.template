# ==================== 墨抄 (MoChao) 环境变量模板 ====================
# 复制此文件为 .env 并填入真实值（.env 已在 .gitignore 中排除）
# 使用方式: IDEA Run Configuration → Environment Variables
# 或: java -jar 时通过 -D 参数传入

# === JWT 配置 ===
# 生成命令 (PowerShell): -join ((1..32) | ForEach-Object { '{0:X2}' -f (Get-Random -Max 256) })
JWT_SECRET=请生成64位随机十六进制字符串替换此处

# === 数据库 ===
DB_URL=jdbc:mysql://192.168.1.100:3306/mochao?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=GMT%2B8&allowPublicKeyRetrieval=true
DB_USERNAME=mochao
DB_PASSWORD=请填入数据库密码

# === Redis ===
REDIS_HOST=192.168.1.100
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=请填入Redis密码

# === AI 大模型 ===
# 使用 DeepSeek（国内直连，推荐）:
#   AI_API_URL=https://api.deepseek.com/v1/chat/completions
#   AI_MODEL=deepseek-chat
# 使用 OpenAI:
#   AI_API_URL=https://api.openai.com/v1/chat/completions
#   AI_MODEL=gpt-4o
AI_PROVIDER=openai
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=请填入API密钥
AI_MODEL=gpt-3.5-turbo
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.8

# === AI 代理（如需访问 OpenAI） ===
# AI_PROXY_HOST=
# AI_PROXY_PORT=

# === 文件上传 ===
MUSIC_UPLOAD_DIR=uploads/music
