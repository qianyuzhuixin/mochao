# ==================== 墨抄 (MoChao) 环境变量模板 ====================
# 复制此文件为 .env 并填入真实值（.env 已在 .gitignore 中排除）
# 使用方式: IDEA Run Configuration → Environment Variables
# 或: java -jar 时通过 -D 参数传入

# === JWT 配置 ===
# ⚠️ 生产环境必须使用强密钥！长度至少 32 字节（256位），推荐 64 字节
# 生成方式:
#   PowerShell: -join ((1..64) | ForEach-Object { '{0:X2}' -f (Get-Random -Max 256) })
#   Bash/OpenSSL: openssl rand -hex 32
#   Java: new SecureRandom().ints(64, 0, 256).mapToObj(i -> String.format("%02x", i)).collect(Collectors.joining())
# ⚠️ 以下为开发环境 ONLY 的临时密钥，生产部署时必须替换！
JWT_SECRET=

# === 数据库 ===
DB_URL=jdbc:mysql://192.168.1.100:3306/mochao?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=GMT%2B8&allowPublicKeyRetrieval=true
DB_USERNAME=mochao
DB_PASSWORD=mochao

# === Redis ===
REDIS_HOST=192.168.1.100
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=root

# === AI 大模型 ===
# 使用 DeepSeek（国内直连，推荐）:
#   AI_API_URL=https://api.deepseek.com/v1/chat/completions
#   AI_MODEL=deepseek-chat
# 使用 OpenAI:
#   AI_API_URL=https://api.openai.com/v1/chat/completions
#   AI_MODEL=gpt-4o
AI_PROVIDER=openai
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=请填入API密钥
AI_MODEL=gpt-3.5-turbo
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.8

# === AI 代理（如需访问 OpenAI） ===
# AI_PROXY_HOST=
# AI_PROXY_PORT=

# === 文件上传 ===
MUSIC_UPLOAD_DIR=uploads/music

# === MinIO 对象存储 ===
# 启动 MinIO: cd mochao && docker-compose up -d
# 访问控制台: http://localhost:9001 (minioadmin / minioadmin)
MINIO_ENDPOINT=http://192.168.1.100:9000
MINIO_ACCESS_KEY=minio_CTA3B7
MINIO_SECRET_KEY=minio_523rdx
MINIO_BUCKET=mochao
# 如果 MinIO 在 Docker 内网，外部访问需要不同的地址，留空则使用 ENDPOINT
MINIO_PUBLIC_ENDPOINT=
